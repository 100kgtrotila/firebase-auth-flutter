# This project uses FlutterFire generated config files instead of reading
# Firebase values directly from .env at runtime.
#
# Keep real Firebase config files local:
# - lib/firebase_options.dart
# - android/app/google-services.json
# - ios/Runner/GoogleService-Info.plist
#
# Regenerate them with:
# flutterfire configure --project=flutter-auth-app-f4d16

FIREBASE_PROJECT_ID=flutter-auth-app-f4d16
